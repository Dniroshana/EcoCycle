<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- FRAME: Header -->
    <LinearLayout
        android:id="@+id/header"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:paddingLeft="32dp"
        android:paddingTop="56dp"
        android:paddingRight="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- FRAME: Button - Go back → SVG -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="true"
            android:focusable="true">

            <!-- VECTOR: Vector -->
            <ImageView
                android:id="@+id/vector"
                android:layout_width="23dp"
                android:layout_height="21dp"
                android:scaleType="fitXY"
                android:src="@drawable/left"
                tools:layout_editor_absoluteX="1dp"
                tools:layout_editor_absoluteY="3dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- FRAME: MainContent -->
    <LinearLayout
        android:id="@+id/maincontent"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="32dp"
        android:paddingTop="32dp"
        android:paddingRight="32dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <!-- FRAME: Container -->
        <LinearLayout
            android:id="@+id/container_heading"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- FRAME: Heading 1 -->
            <LinearLayout
                android:id="@+id/heading_1"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- TEXT: Forgot Password? -->
                <TextView
                    android:id="@+id/forgot_password_"
                    android:text="Forgot Password?"
                    android:textSize="32sp"
                    android:textColor="#FF111827"
                    android:gravity="start"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container_subtext"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <!-- TEXT: Don't worry! Enter your email address below to receive a password reset link. -->
                <TextView
                    android:id="@+id/don_t_worry__enter_your_email_address_below_to_receive_a_password_reset_link_"
                    android:text="Don't worry! Enter your email address\nbelow to receive a password reset link."
                    android:textSize="16sp"
                    android:textColor="#FF6B7280"
                    android:gravity="start"
                    android:fontFamily="sans-serif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: InputSection -->
        <LinearLayout
            android:id="@+id/inputsection"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp">

            <!-- FRAME: Label -->
            <TextView
                android:id="@+id/email_address"
                android:text="EMAIL ADDRESS"
                android:textSize="12sp"
                android:textColor="#FF6B7280"
                android:gravity="start"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- FRAME: Container -->
            <RelativeLayout
                android:id="@+id/container_input"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded">

                <ImageView
                    android:id="@+id/ivEnvelope"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_vector"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    app:tint="#FF9CA3AF" />

                <EditText
                    android:id="@+id/etForgotEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivEnvelope"
                    android:background="@android:color/transparent"
                    android:hint="Enter your registered email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="12dp"
                    android:textSize="16sp"
                    android:textColor="#FF111827"
                    android:textColorHint="#FF9CA3AF"
                    android:fontFamily="sans-serif" />
            </RelativeLayout>
        </LinearLayout>

        <!-- FRAME: ActionSection → Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendResetLink"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Send Reset Link"
            android:textSize="18sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:textAllCaps="false"
            android:backgroundTint="#FF10B981"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- FRAME: Footer -->
    <LinearLayout
        android:id="@+id/footer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvSupport"
            android:text="Still having trouble? Contact Support"
            android:textSize="14sp"
            android:textColor="#FF6B7280"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>