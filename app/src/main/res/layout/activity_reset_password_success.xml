<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- Success Content Container -->
    <LinearLayout
        android:id="@+id/main_content_canvas"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footer">

        <!-- Success Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F0FDF4"
            android:layout_marginBottom="40dp">

            <ImageView
                android:id="@+id/icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_circle"
                app:tint="#FF10B981" />
        </androidx.cardview.widget.CardView>

        <!-- Feedback Message -->
        <TextView
            android:id="@+id/tvSuccessTitle"
            android:text="Password Updated\nSuccessfully!"
            android:textSize="32sp"
            android:textColor="#FF171D18"
            android:gravity="center"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvSuccessDesc"
            android:text="Your account is secure again. You can\nnow log in with your new password."
            android:textSize="16sp"
            android:textColor="#FF3E4A3F"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="64dp" />

        <!-- Back to Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Login"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            android:backgroundTint="#FF10B981" />

    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFFFF"
        android:padding="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Need help? Contact EcoCycle Support"
            android:textColor="#FF3E4A3F"
            android:textSize="14sp" />

        <TextView
            android:text="© 2026 ECOCYCLE. ALL RIGHTS RESERVED."
            android:textSize="12sp"
            android:textColor="#FF3E4A3F"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>