<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBF8">

    <!-- Header Container -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="#FFF5FBF2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Button (Back) -->
        <LinearLayout
            android:id="@+id/btn_back_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/left"
                app:tint="#0E9E6D" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Entry"
            android:textSize="22sp"
            android:textColor="#0E9E6D"
            android:gravity="center"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Button (Delete) -->
        <LinearLayout
            android:id="@+id/btn_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/trash"
                app:tint="#B04E4E" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Current Impact Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#F0F9F4"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT IMPACT"
                        android:textColor="#FF006A39"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+12 EcoPoints"
                        android:textColor="#FF171D18"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saved 2.4kg of CO2 equivalent."
                        android:textColor="#FF3E4A3F"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/leaf"
                    app:tint="#C3D9C3" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="JOURNAL ENTRY"
                android:textColor="#FF3E4A3F"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Main Entry Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#FFFFFF"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/et_entry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="top"
                    android:minHeight="150dp"
                    android:text="Sorted 3 glass bottles and 2 aluminum soda cans from the weekly office lunch. All items cleaned before disposal."
                    android:textColor="#FF171D18"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E2E8F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attachment"
                    android:textColor="#FF3E4A3F"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Attachment Upload Area -->
                <FrameLayout
                    android:id="@+id/attachment_container"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_dashed_border"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:id="@+id/placeholder_content"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_pill"
                            android:backgroundTint="#FFFFFF">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/camera"
                                app:tint="#0E9E6D" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Tap to upload or take a photo"
                            android:textColor="#4A5568"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="JPEG, PNG up to 10MB"
                            android:textColor="#718096"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- ImageView to show preview of selected image -->
                    <ImageView
                        android:id="@+id/img_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </FrameLayout>
            </LinearLayout>

            <!-- Date and Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="LOG DATE"
                android:textColor="#FF3E4A3F"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/date_picker_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#F0F9F4"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_log_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10/24/2023"
                    android:textColor="#FF171D18"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CATEGORY (OPTIONAL)"
                android:textColor="#FF3E4A3F"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#D1E9D1"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Recyclable"
                    android:textColor="#FF006A39"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#F1F5F9"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Other"
                    android:textColor="#FF3E4A3F" />
            </LinearLayout>

            <!-- Weekly Goal Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#F0F9F4"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="WEEKLY GOAL"
                        android:textColor="#FF006A39"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="84%"
                        android:textColor="#FF171D18"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="84"
                    android:progressTint="#FF006A39" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_update_entry"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#FF006A39"
                android:text="Save to Diary"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart" />

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>