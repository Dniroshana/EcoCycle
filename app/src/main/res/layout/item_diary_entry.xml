<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_rounded"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_entry_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/wel_generated" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_entry_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Recycling Activity"
                android:textColor="#171D18"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_entry_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 10/24/2023"
                android:textColor="#3E4A3F"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_edit_entry"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/pen"
            app:tint="#0E9E6D" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_entry_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Entry description goes here..."
        android:textColor="#3E4A3F"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#F0F9F4"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="+150 pts"
        android:textColor="#006A39"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>