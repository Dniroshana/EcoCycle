<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5FBF2">

    <!-- Header Section (Title Only, Centered) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="#FFF5FBF2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Delete Account"
            android:textColor="#0E9E6D"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Content Container (No Scroll) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Warning Icon -->
        <FrameLayout
            android:id="@+id/warning_icon_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#FFE7E8"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/trash"
                app:tint="#FFBA1A1A" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Are you sure you want\nto leave EcoCycle?"
            android:textSize="28sp"
            android:textColor="#FF171D18"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/warning_icon_container" />

        <TextView
            android:id="@+id/tv_subtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This action will permanently delete your\naccount profile, recycle history, and all\nthe progress you've made for the planet."
            android:textSize="14sp"
            android:textColor="#FF3E4A3F"
            android:gravity="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_headline" />

        <TextView
            android:id="@+id/tv_lose_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What you will lose"
            android:textSize="20sp"
            android:textColor="#FF171D18"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtext" />

        <!-- EcoPoints Card -->
        <LinearLayout
            android:id="@+id/card_ecopoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#FFFFFF"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:elevation="1dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_lose_label">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#F0F9F4"
                android:padding="10dp"
                android:src="@drawable/leaf"
                app:tint="#0E9E6D" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,250 EcoPoints"
                    android:textSize="16sp"
                    android:textColor="#FF171D18"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equivalent to 5 tree plantings"
                    android:textSize="14sp"
                    android:textColor="#FF3E4A3F" />
            </LinearLayout>
        </LinearLayout>

        <!-- Impact Reports Card -->
        <LinearLayout
            android:id="@+id/card_impact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#FFFFFF"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:elevation="1dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/card_ecopoints">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#F0F9F4"
                android:padding="10dp"
                android:src="@drawable/history"
                app:tint="#0E9E6D" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Impact Reports"
                    android:textSize="16sp"
                    android:textColor="#FF171D18"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historical data on your carbon offset"
                    android:textSize="14sp"
                    android:textColor="#FF3E4A3F" />
            </LinearLayout>
        </LinearLayout>

        <!-- Footer Text -->
        <TextView
            android:id="@+id/tv_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Once deleted, this data cannot be recovered.\nWe're sad to see you go!"
            android:textColor="#FF3E4A3F"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Confirm Delete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_delete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Delete My Account"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFBA1A1A"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toTopOf="@id/tv_footer" />

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Cancel, Keep My Account"
            android:textAllCaps="false"
            android:textColor="#FF171D18"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#E8EDE8"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toTopOf="@id/btn_confirm_delete" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>