<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- Navigation -->
    <LinearLayout
        android:id="@+id/navigation_margin"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingTop="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/navigation"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/vector"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/left"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- HeaderSection -->
    <LinearLayout
        android:id="@+id/headersection_margin"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/navigation_margin">

        <TextView
            android:id="@+id/reset_password"
            android:text="Reset Password"
            android:textSize="32sp"
            android:textColor="#FF0F172A"
            android:gravity="start"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/please_create_a_secure_password"
            android:text="Please create a secure password that\nyou haven't used before for EcoCycle."
            android:textSize="18sp"
            android:textColor="#FF64748B"
            android:gravity="start"
            android:fontFamily="sans-serif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- ResetForm -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headersection_margin"
        app:layout_constraintBottom_toTopOf="@id/footersection">

        <LinearLayout
            android:id="@+id/resetform"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp">

            <!-- NEW PASSWORD -->
            <TextView
                android:text="NEW PASSWORD"
                android:textSize="12sp"
                android:textColor="#FF94A3B8"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="63dp"
                android:background="@drawable/bg_rounded">

                <ImageView
                    android:id="@+id/ivLock"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_vector"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    app:tint="#FF94A3B8" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivLock"
                    android:background="@android:color/transparent"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FF0F172A"
                    android:textColorHint="#FF94A3B8" />
            </RelativeLayout>

            <!-- Password Strength Indicator -->
            <LinearLayout
                android:id="@+id/password_strength_indicator"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#E2E8F0" android:layout_marginEnd="4dp" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#E2E8F0" android:layout_marginEnd="4dp" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#E2E8F0" android:layout_marginEnd="4dp" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#E2E8F0" />
            </LinearLayout>

            <TextView
                android:text="Enter at least 8 characters"
                android:textSize="12sp"
                android:textColor="#FF94A3B8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <!-- CONFIRM NEW PASSWORD -->
            <TextView
                android:text="CONFIRM NEW PASSWORD"
                android:textSize="12sp"
                android:textColor="#FF94A3B8"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="63dp"
                android:background="@drawable/bg_rounded">

                <ImageView
                    android:id="@+id/ivShield"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_vector"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    app:tint="#FF94A3B8" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivShield"
                    android:background="@android:color/transparent"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FF0F172A"
                    android:textColorHint="#FF94A3B8" />
            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="64dp"
                android:text="Update Password"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="#FF10B981" />

        </LinearLayout>
    </ScrollView>

    <!-- FooterSection -->
    <LinearLayout
        android:id="@+id/footersection"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        android:paddingHorizontal="32dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:text="EcoCycle uses 256-bit encryption to keep\nyour data safe."
            android:textSize="14sp"
            android:textColor="#FF94A3B8"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>