<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".SchedulePickupActivity">

    <!-- Header Container -->
    <LinearLayout
        android:id="@+id/header___top_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="#FFF5FBF2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Button (Back) -->
        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@drawable/left"
                app:tint="#000000" />
        </LinearLayout>

        <!-- Title (Centered) -->
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Schedule Pickup"
            android:textSize="24sp"
            android:textColor="#0E9E6D"
            android:gravity="center"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Balanced space to keep title centered -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- Content Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_confirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header___top_appbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Select Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Date"
                android:textColor="@color/text_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <CalendarView
                android:id="@+id/calendar_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded"
                android:padding="8dp"
                android:theme="@style/Theme.EcoCycleConnect" />

            <!-- Select Time -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Select Time"
                android:textColor="@color/text_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Time Slots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <!-- Morning -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_morning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_selected_item"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_morning"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Morning Icon"
                        android:src="@drawable/morning"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                    <TextView
                        android:id="@+id/tv_morning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Morning"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/icon_morning"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_morning_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00 - 10:00 AM"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tv_morning"
                        app:layout_constraintTop_toBottomOf="@id/tv_morning" />

                    <ImageView
                        android:id="@+id/check_morning"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Selected Check"
                        android:src="@drawable/ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        android:visibility="visible" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Mid-Day -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_midday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_rounded"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_midday"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Mid-Day Icon"
                        android:src="@drawable/sunny"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_light_grey" />

                    <TextView
                        android:id="@+id/tv_midday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Mid-Day"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/icon_midday"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_midday_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10:00 - 12:00 PM"
                        android:textColor="@color/text_light_grey"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tv_midday"
                        app:layout_constraintTop_toBottomOf="@id/tv_midday" />

                    <ImageView
                        android:id="@+id/check_midday"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Selected Check"
                        android:src="@drawable/ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        android:visibility="gone" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Afternoon -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_afternoon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_afternoon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Afternoon Icon"
                        android:src="@drawable/cloud"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_light_grey" />

                    <TextView
                        android:id="@+id/tv_afternoon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Afternoon"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/icon_afternoon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_afternoon_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02:00 - 04:00 PM"
                        android:textColor="@color/text_light_grey"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/tv_afternoon"
                        app:layout_constraintTop_toBottomOf="@id/tv_afternoon" />

                    <ImageView
                        android:id="@+id/check_afternoon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Selected Check"
                        android:src="@drawable/ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        android:visibility="gone" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <!-- Type of Waste -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Type of Waste"
                android:textColor="@color/text_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2"
                android:rowCount="3">

                <!-- Plastic -->
                <LinearLayout
                    android:id="@+id/layout_plastic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_plastic"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Plastic"
                        android:src="@drawable/waterbottle" />

                    <TextView
                        android:id="@+id/tv_plastic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Plastic"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

                <!-- Organic -->
                <LinearLayout
                    android:id="@+id/layout_organic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_organic"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Organic"
                        android:src="@drawable/compost" />

                    <TextView
                        android:id="@+id/tv_organic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Organic"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

                <!-- Paper -->
                <LinearLayout
                    android:id="@+id/layout_paper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_paper"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Paper"
                        android:src="@drawable/paperstack" />

                    <TextView
                        android:id="@+id/tv_paper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Paper"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

                <!-- Glass -->
                <LinearLayout
                    android:id="@+id/layout_glass"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_glass"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Glass"
                        android:src="@drawable/glass34" />

                    <TextView
                        android:id="@+id/tv_glass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Glass"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

                <!-- Electronic -->
                <LinearLayout
                    android:id="@+id/layout_electronic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_electronic"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Electronic"
                        android:src="@drawable/ewaste" />

                    <TextView
                        android:id="@+id/tv_electronic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Electronic"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

                <!-- Other -->
                <LinearLayout
                    android:id="@+id/layout_other"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/icon_other"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Other"
                        android:src="@drawable/garbage234" />

                    <TextView
                        android:id="@+id/tv_other"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Other"
                        android:textSize="12sp"
                        android:textColor="@color/text_black" />
                </LinearLayout>

            </GridLayout>

            <!-- Select Vehicle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Select Vehicle"
                android:textColor="@color/text_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Vehicle 1 (Selected) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_vehicle_small"
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_selected_item"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iv_vehicle1"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Vehicle Icon 1"
                            android:src="@drawable/small_pickup2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                             />

                        <ImageView
                            android:id="@+id/check_vehicle_small"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="Selected Icon"
                            android:src="@drawable/ic_check_circle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/white"
                            android:visibility="visible" />

                        <TextView
                            android:id="@+id/tv_v1_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Small Pickup"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iv_vehicle1" />

                        <TextView
                            android:id="@+id/tv_v1_capacity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Up to 500kg"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_v1_name" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Vehicle 2 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_vehicle_standard"
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iv_vehicle2"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Vehicle Icon 2"
                            android:src="@drawable/standard_truck2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/check_vehicle_standard"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="Selected Icon"
                            android:src="@drawable/ic_check_circle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/white"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_v2_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Standard Truck"
                            android:textColor="@color/text_black"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iv_vehicle2" />

                        <TextView
                            android:id="@+id/tv_v2_capacity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Up to 2,000kg"
                            android:textColor="@color/text_light_grey"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_v2_name" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Vehicle 3 (Heavy Duty Truck) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_vehicle_heavy"
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iv_vehicle3"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Vehicle Icon 3"
                            android:src="@drawable/heavy_duty_truck"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/check_vehicle_heavy"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="Selected Icon"
                            android:src="@drawable/ic_check_circle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/white"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_v3_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Heavy Duty Truck"
                            android:textColor="@color/text_black"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iv_vehicle3" />

                        <TextView
                            android:id="@+id/tv_v3_capacity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Up to 8,000kg"
                            android:textColor="@color/text_light_grey"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_v3_name" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Sorting Guidelines -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_guidelines"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/icon_guidelines"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Guidelines Icon"
                    android:src="@drawable/help"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/dark_green" />

                <TextView
                    android:id="@+id/tv_guidelines_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Sorting Guidelines"
                    android:textColor="@color/dark_green"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/icon_guidelines"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Please ensure all items are cleaned, dried, and separated into the respective categories. Hazardous materials are not accepted for residential pickup."
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tv_guidelines_title"
                    app:layout_constraintTop_toBottomOf="@id/tv_guidelines_title" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Extra space for button padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Confirm Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_rounded_button"
        android:text="Confirm &amp; Continue"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
